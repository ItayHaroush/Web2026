APP_NAME="TakeEat IL"
APP_ENV=local
APP_KEY=base64:YOUR_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

# Super-admin analytics: platform owner email (filter "with me / without me" + visitor breakdown)
PLATFORM_OWNER_EMAIL=itay666@icloud.com
# Same person's registered customer (B2C) — Israeli mobile, stored as E164 in DB
PLATFORM_OWNER_CUSTOMER_PHONE=0547466508

# Development Mode - Bypasses billing & AI credits (local/staging only)
DEV_MODE=true

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SMS / OTP
# Pilot mode:
# - true  => force Twilio (pilot)
# - false => use 019
SMS_PILOT=false

# Provider options: twilio | sms019 | 019
SMS_PROVIDER=twilio

# 019sms (Bearer)
# Request format expects:
# {"sms":{"user":{"username":"..."},"source":"...","destinations":{"phone":["9725XXXXXXXX"]},"message":"..."}}
SMS_019_ENDPOINT=https://019sms.co.il/api
SMS_019_USERNAME=
SMS_019_TOKEN=
SMS_019_SOURCE=05XXXXXXXX
SMS_019_TIMEOUT=10

# Twilio (fallback)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=TakeEat
DB_USERNAME=root
DB_PASSWORD=

# אופציונלי: נתיב מלא ל-mysqldump לגיבוי מפאנל סופר-אדמין (PHP לעיתים בלי Homebrew ב-PATH)
# macOS Apple Silicon: /opt/homebrew/bin/mysqldump  (brew install mysql-client)
# macOS Intel:       /usr/local/bin/mysqldump
# Linux:             /usr/bin/mysqldump  (apt install mariadb-client)
# MYSQLDUMP_PATH=/opt/homebrew/bin/mysqldump

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# דוא״ל — אפשרויות: log | smtp | ses | postmark | resend (דורש חבילה) | וכו'
# לייצור: העדף SMTP מאומת דומיין (Google Workspace / ESP) עם TLS.
# Gmail/Google Workspace: smtp.gmail.com, 587, MAIL_ENCRYPTION=tls, סיסמת אפליקציה או OAuth.
# לנפח גבוה: שקול SES / SendGrid / Mailgun עם אימות SPF+DKIM+DMARC בדומיין ה-From.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# השהייה בשניות בין כל שליחה בשליחה גורפת / מיילי ניסיון (מניעת burst ומגבלות SMTP)
MAIL_BULK_DELAY_SECONDS=2

VITE_API_URL=http://localhost:8000/api

# ==============================================
# AI Provider Configuration
# ==============================================
# AI_PROVIDER options:
#   - 'copilot' => GitHub Copilot CLI (local development ONLY)
#   - 'openai'  => OpenAI HTTP API (production/server)
#
# 🔒 Security: Copilot CLI is automatically blocked in production
# 📌 Recommendation: Use 'copilot' locally, 'openai' in production
AI_PROVIDER=copilot

# GitHub Copilot SDK Configuration (Local Development)
# Only active when AI_PROVIDER=copilot
COPILOT_ENABLED=true
COPILOT_MODE=mock                    # Options: 'mock' (free testing) | 'real' (actual CLI)
COPILOT_CLI_PATH="/path/to/copilot"  # Path to Copilot CLI executable
COPILOT_CACHE_ENABLED=true
COPILOT_CACHE_TTL=86400              # 24 hours

# OpenAI Configuration (Production)
# Only active when AI_PROVIDER=openai
OPENAI_API_KEY=                      # ⚠️  Required for production (get from platform.openai.com)
OPENAI_MODEL=gpt-4o-mini             # Options: gpt-4o-mini (cheap) | gpt-4 (better quality)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=30
OPENAI_MOCK=false                    # Set to 'true' for testing without API costs

# Stability AI Configuration (Image Enhancement ONLY)
# Used for img2img enhancement (preserves original dish appearance)
STABILITY_API_KEY=                   # ⚠️  Required for image enhancement (get from platform.stability.ai)
STABILITY_API_URL=https://api.stability.ai/v2beta/stable-image/generate/sd3

# AI Features Rate Limiting (per tenant per month)
AI_FREE_TIER_CREDITS=20
AI_BASIC_TIER_CREDITS=0
AI_PRO_TIER_CREDITS=500              # Pro trial gets 50, Pro paid gets 500
AI_RATE_LIMIT_PER_MINUTE=10

# AI Cost Tracking
AI_LOG_USAGE=true

# ==============================================
# Payment / Credit Card Configuration
# ==============================================
# דגל גלובלי להפעלת תשלום באשראי - ברירת מחדל כבוי
# הפעל רק אחרי שחיבור HYP מוכן לייצור
CREDIT_CARD_ENABLED=false

# HYP Platform Terminal (B2B) - מסוף TakeEat לחיוב מנויי מסעדות
# נפרד ממסוף B2C של כל מסעדה
HYP_MASOF=
HYP_PASSP=
HYP_API_KEY=

# דגל לחיוב מנויי מסעדות (B2B) דרך הקרון
# כאשר false - הפקודה billing:charge-subscriptions לא תרוץ גם אם יש schedule:run
# ברירת מחדל true לשמירה על תאימות לאחור (production)
SUBSCRIPTION_BILLING_ENABLED=true

# ==============================================
# Z-Credit — POS / PinPad (CommitFullTransaction)
# ==============================================
# מסופון אמיתי: עדכן לפי Z-Credit. מעבר דמה→ייצור = רק .env (בלי שינוי קוד).
# אימות מקומי ללא HTTP: php artisan zcredit:verify-config
# מדריך בדיקות: docs/zcredit-pinpad-testing.md
ZCREDIT_TERMINAL_NUMBER=
ZCREDIT_TERMINAL_PASSWORD=
# API Key אם נדרש בתרחישים עתידיים (ברירת מחדל בקונפיג לפיתוח בלבד)
ZCREDIT_API_KEY=
# מזהה PinPad — בקוד יהפוך ל־Track2: PINPAD{מזהה}
ZCREDIT_PINPAD_ID=11002
# עתידי: נתיבי בדיקה נפרדים — לא משנים את chargePinPad
ZCREDIT_TEST_MODE=false
# true = רושם POST /api/zcredit/test-pinpad-charge (חשוף, ללא auth). רק בדיקה זמנית בשרת
ZCREDIT_ALLOW_TEST_ROUTE=false

